{
  "rewrites": [
    {
      "source": "/api/health",
      "destination": "https://watch-the-code.onrender.com/health"
    },
    {
      "source": "/api/(.*)",
      "destination": "https://watch-the-code.onrender.com/api/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
